{
  "manifest_version": 3,
  "name": "Autotask Enhancement Suite",
  "description": "Enhancements for Autotask, including the custom tab shell for tickets, accounts, contracts, and clickable phone numbers.",
  "version": "0.4.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "autotask-enhancement-suite@quintenvannoorloos.nl",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.autotask.net/*"
      ],
      "all_frames": true,
      "js": [
        "aes-shared.js",
        "aes-storage.js",
        "aes-phone-links.js",
        "aes-iframe-bridge.js",
        "aes-shell.js",
        "content-tabs.js"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage"
  ],
  "background": {
    "scripts": ["aes-background.js"]
  },
  "host_permissions": [
    "https://*.autotask.net/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "aes-page-bridge.js"
      ],
      "matches": [
        "https://*.autotask.net/*"
      ]
    }
  ],
  "action": {
    "default_title": "Autotask Enhancement Suite",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
