{
  "manifest_version": 3,
  "name": "AES: Tabs for Autotask",
  "description": "Enhancements for Autotask, including the custom tab shell for tickets, accounts, contracts, and clickable phone numbers.",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "autotask-enhancement-suite@quintenvannoorloos.nl",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.autotask.net/*"
      ],
      "exclude_matches": [
        "https://*.autotask.net/help/Content/*",
        "https://*.autotask.net/help/content/*",
        "https://www.autotask.net/*"
      ],
      "all_frames": true,
      "js": [
        "src/aes-local-flags.js",
        "src/aes-routes.js",
        "src/aes-shared.js",
        "src/aes-storage.js",
        "src/aes-phone-links.js",
        "src/aes-shell-runtime.js",
        "src/aes-shell-config.js",
        "src/aes-shell-styles.js",
        "src/aes-iframe-runtime.js",
        "src/aes-iframe-bridge.js",
        "src/aes-shell-settings-ui.js",
        "src/aes-shell.js",
        "src/content-tabs.js"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "storage": {
    "managed_schema": "managed_schema.json"
  },
  "background": {
    "scripts": [
      "src/aes-local-flags.js",
      "src/aes-routes.js",
      "src/aes-background.js"
    ]
  },
  "host_permissions": [
    "https://*.autotask.net/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/aes-routes.js",
        "src/aes-page-bridge.js"
      ],
      "matches": [
        "https://*.autotask.net/*"
      ]
    }
  ],
  "action": {
    "default_title": "AES: Tabs for Autotask",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "commands": {
    "close-all-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "MacCtrl+Shift+X"
      },
      "description": "Close all AES tabs"
    }
  }
}
